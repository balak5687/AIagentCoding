import 'package:flutter/material.dart';
import '../../models/dashboard.dart';
import 'line_chart_widget.dart';

/// Revenue Trend Chart Widget
///
/// Displays a 7-day revenue trend with gradient fill, tooltips, and summary
class RevenueTrendChart extends StatelessWidget {
  final ChartData chartData;
  final double? height;

  const RevenueTrendChart({
    Key? key,
    required this.chartData,
    this.height = 300,
  }) : super(key: key);

  @override
  Widget build(BuildContext context) {
    final theme = Theme.of(context);
    
    // Calculate total revenue
    final totalRevenue = chartData.data.fold<double>(
      0.0,
      (sum, dataPoint) => sum + dataPoint.value,
    );

    return Column(
      crossAxisAlignment: CrossAxisAlignment.stretch,
      children: [
        // Line chart with area fill (gradient)
        LineChartWidget(
          chartData: _buildRevenueChartData(),
          height: height,
        ),
        
        const SizedBox(height: 16),
        
        // Total revenue summary
        _buildRevenueSummary(context, theme, totalRevenue),
      ],
    );
  }

  /// Build chart data configured for revenue display
  ChartData _buildRevenueChartData() {
    return ChartData(
      title: chartData.title.isEmpty ? '7-Day Revenue Trend' : chartData.title,
      type: 'area', // Area chart for gradient fill
      data: chartData.data,
      xAxisLabel: chartData.xAxisLabel ?? 'Day',
      yAxisLabel: chartData.yAxisLabel ?? 'Revenue (\$)',
      showLegend: chartData.showLegend,
      showGrid: chartData.showGrid,
    );
  }

  /// Build revenue summary card
  Widget _buildRevenueSummary(BuildContext context, ThemeData theme, double totalRevenue) {
    return Card(
      elevation: 2,
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(12),
      ),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Total Revenue',
                  style: theme.textTheme.titleMedium?.copyWith(
                    color: theme.colorScheme.onSurfaceVariant,
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  _formatCurrency(totalRevenue),
                  style: theme.textTheme.headlineMedium?.copyWith(
                    fontWeight: FontWeight.bold,
                    color: theme.colorScheme.primary,
                  ),
                ),
              ],
            ),
            Icon(
              Icons.attach_money,
              size: 48,
              color: theme.colorScheme.primary.withOpacity(0.3),
            ),
          ],
        ),
      ),
    );
  }

  /// Format value as currency
  String _formatCurrency(double value) {
    if (value.abs() >= 1000000) {
      return '\$${(value / 1000000).toStringAsFixed(2)}M';
    } else if (value.abs() >= 1000) {
      return '\$${(value / 1000).toStringAsFixed(2)}K';
    } else {
      return '\$${value.toStringAsFixed(2)}';
    }
  }
}