import 'package:flutter/material.dart';
import '../../services/work_order_service.dart';
import '../../models/work_order.dart';

// Status constants to avoid magic strings
class WorkOrderStatus {
  static const String pending = 'pending';
  static const String inProgress = 'in_progress';
  static const String completed = 'completed';
  static const String cancelled = 'cancelled';
  static const String onHold = 'on_hold';
}

class ServiceStatus {
  static const String scheduled = 'scheduled';
  static const String inProgress = 'in_progress';
  static const String ready = 'ready';
  static const String pickedUp = 'picked_up';
}

class DeliveryStatus {
  static const String pending = 'pending';
  static const String dispatched = 'dispatched';
  static const String delivered = 'delivered';
  static const String failed = 'failed';
}

class JobsSnapshotTable extends StatefulWidget {
  final WorkOrderService workOrderService;
  final String? statusFilter;
  final int maxRows;

  const JobsSnapshotTable({
    super.key,
    required this.workOrderService,
    this.statusFilter,
    this.maxRows = 10,
  });

  @override
  State<JobsSnapshotTable> createState() => _JobsSnapshotTableState();
}

class _JobsSnapshotTableState extends State<JobsSnapshotTable> {
  List<WorkOrder> _workOrders = [];
  bool _isLoading = true;
  String? _errorMessage;

  @override
  void initState() {
    super.initState();
    _loadWorkOrders();
  }

  Future<void> _loadWorkOrders() async {
    setState(() {
      _isLoading = true;
      _errorMessage = null;
    });

    try {
      final workOrders = await widget.workOrderService.getWorkOrders(
        status: widget.statusFilter,
        limit: widget.maxRows,
      );
      
      setState(() {
        _workOrders = workOrders;
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _errorMessage = 'Failed to load work orders: $e';
        _isLoading = false;
      });
    }
  }

  // Normalize status string for consistent comparison
  String _normalizeStatus(String? status) {
    if (status == null) return '';
    return status.toLowerCase().replaceAll(' ', '_').trim();
  }

  // Main work order status colors
  Color _getStatusColor(String? status) {
    if (status == null) return Colors.grey;
    
    final normalized = _normalizeStatus(status);
    switch (normalized) {
      case 'pending':
        return Colors.orange;
      case 'in_progress':
        return Colors.blue;
      case 'completed':
        return Colors.green;
      case 'cancelled':
        return Colors.red;
      case 'on_hold':
        return Colors.amber;
      default:
        return Colors.grey;
    }
  }

  // Service status colors (scheduled, in_progress, ready, picked_up)
  Color _getServiceStatusColor(String? status) {
    if (status == null) return Colors.grey;
    
    final normalized = _normalizeStatus(status);
    switch (normalized) {
      case 'scheduled':
        return Colors.purple;
      case 'in_progress':
        return Colors.blue;
      case 'ready':
        return Colors.lightGreen;
      case 'picked_up':
        return Colors.green;
      default:
        return Colors.grey;
    }
  }

  // Delivery status colors (pending, dispatched, delivered, failed)
  Color _getDeliveryStatusColor(String? status) {
    if (status == null) return Colors.grey;
    
    final normalized = _normalizeStatus(status);
    switch (normalized) {
      case 'pending':
        return Colors.orange;
      case 'dispatched':
        return Colors.blue;
      case 'delivered':
        return Colors.green;
      case 'failed':
        return Colors.red;
      default:
        return Colors.grey;
    }
  }

  Widget _buildStatusChip(String? status, Color Function(String?) colorFunction) {
    final displayStatus = status ?? 'N/A';
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: colorFunction(status).withOpacity(0.2),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: colorFunction(status),
          width: 1,
        ),
      ),
      child: Text(
        displayStatus.replaceAll('_', ' ').toUpperCase(),
        style: TextStyle(
          color: colorFunction(status),
          fontSize: 12,
          fontWeight: FontWeight.bold,
        ),
      ),
    );
  }

  String _formatVehicleInfo(WorkOrder workOrder) {
    // Handle structured vehicle data (make, model, plate)
    if (workOrder.vehicle != null) {
      final vehicle = workOrder.vehicle!;
      final make = vehicle.make ?? '';
      final model = vehicle.model ?? '';
      final plate = vehicle.licensePlate ?? vehicle.plate ?? '';
      
      if (make.isNotEmpty || model.isNotEmpty) {
        final vehicleDesc = [make, model].where((s) => s.isNotEmpty).join(' ');
        return plate.isNotEmpty ? '$vehicleDesc ($plate)' : vehicleDesc;
      }
      
      return plate.isNotEmpty ? plate : 'N/A';
    }
    
    // Fallback to vehicleInfo string field if available
    if (workOrder.vehicleInfo != null && workOrder.vehicleInfo!.isNotEmpty) {
      return workOrder.vehicleInfo!;
    }
    
    return 'N/A';
  }

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 2,
      child: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                const Text(
                  'Jobs Snapshot',
                  style: TextStyle(
                    fontSize: 18,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                if (_isLoading)
                  const SizedBox(
                    width: 16,
                    height: 16,
                    child: CircularProgressIndicator(strokeWidth: 2),
                  ),
              ],
            ),
            const SizedBox(height: 16),
            if (_errorMessage != null)
              Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  color: Colors.red.withOpacity(0.1),
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: Colors.red),
                ),
                child: Row(
                  children: [
                    const Icon(Icons.error_outline, color: Colors.red),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text(
                        _errorMessage!,
                        style: const TextStyle(color: Colors.red),
                      ),
                    ),
                  ],
                ),
              )
            else if (_workOrders.isEmpty && !_isLoading)
              const Center(
                child: Padding(
                  padding: EdgeInsets.all(24.0),
                  child: Text(
                    'No work orders found',
                    style: TextStyle(
                      fontSize: 14,
                      color: Colors.grey,
                    ),
                  ),
                ),
              )
            else
              SingleChildScrollView(
                scrollDirection: Axis.horizontal,
                child: DataTable(
                  columns: const [
                    DataColumn(label: Text('Vehicle')),
                    DataColumn(label: Text('Job ID')),
                    DataColumn(label: Text('Issue Type')),
                    DataColumn(label: Text('Status')),
                    DataColumn(label: Text('Technician')),
                    DataColumn(label: Text('Service Status')),
                    DataColumn(label: Text('Delivery Status')),
                    DataColumn(label: Text('Delay Reason')),
                  ],
                  rows: _workOrders.map((workOrder) {
                    return DataRow(
                      onSelectChanged: (_) {
                        // Navigate to job detail page
                        Navigator.pushNamed(
                          context,
                          '/job-detail',
                          arguments: workOrder.id,
                        );
                      },
                      cells: [
                        DataCell(Text(_formatVehicleInfo(workOrder))),
                        DataCell(Text(workOrder.jobId ?? 'N/A')),
                        DataCell(Text(workOrder.issueType ?? 'N/A')),
                        DataCell(_buildStatusChip(workOrder.status, _getStatusColor)),
                        DataCell(Text(workOrder.technicianName ?? 'Unassigned')),
                        DataCell(_buildStatusChip(workOrder.serviceStatus, _getServiceStatusColor)),
                        DataCell(_buildStatusChip(workOrder.deliveryStatus, _getDeliveryStatusColor)),
                        DataCell(Text(workOrder.delayReason ?? '-')),
                      ],
                    );
                  }).toList(),
                ),
              ),
          ],
        ),
      ),
    );
  }
}